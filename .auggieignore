# Auggie ignore file - patterns to exclude from Augment context engine

# Dependencies
node_modules/

# Build outputs
dist/
build/

# Coverage reports
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Temporary files
*.tmp
.cache/
