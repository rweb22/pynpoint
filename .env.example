# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pinpointindia

# Migrations
RUN_MIGRATIONS=false

# Redis (Dual-Instance Architecture)
# See docs/architecture/REDIS_DUAL_INSTANCE_ARCHITECTURE.md
REDIS_PERSISTENT_URL=redis://localhost:6379/0  # H3 spatial index (noeviction, RDB snapshots)
REDIS_CACHE_URL=redis://localhost:6379/1       # API auth, rate limiting (allkeys-lru, no persistence)
REDIS_URL=redis://localhost:6379                # Legacy fallback

# Data Ingestion
PINCODE_DATA_URL=https://pub-0429b8e3b5a946e69ea007df844a6f1c.r2.dev/postal/boundaries/Datagov_Pincode_Boundaries.geojson
PINCODE_DATA_CHECKSUM=
FORCE_REINGEST_DATA=false

# H3 Index
H3_RESOLUTION=9
H3_BUFFER_ENABLED=true
FORCE_REBUILD_H3_INDEX=false

# Initialization
SKIP_INITIALIZATION=false

# API Authentication (Phase 3+)
# See docs/deployment/ENVIRONMENT_VARIABLES.md
ADMIN_API_SECRET=your-super-secret-admin-key-change-this-in-production
JWT_SECRET=your-jwt-secret-change-this-in-production
API_KEY_SALT=your-random-salt-for-key-generation

# Rate Limiting (Configurable per Tier)
# Aligned with RapidAPI standards: FREE tier = 1,000 req/month baseline
#
# FREE tier (default: 10 req/min, 100 req/day, 1,000 req/month)
RATE_LIMIT_FREE_PER_MINUTE=10
RATE_LIMIT_FREE_PER_DAY=100
RATE_LIMIT_FREE_PER_MONTH=1000

# PRO tier (default: 100 req/min, 1,000 req/day, 10,000 req/month)
RATE_LIMIT_PRO_PER_MINUTE=100
RATE_LIMIT_PRO_PER_DAY=1000
RATE_LIMIT_PRO_PER_MONTH=10000

# BUSINESS tier (default: 500 req/min, 5,000 req/day, 100,000 req/month)
RATE_LIMIT_BUSINESS_PER_MINUTE=500
RATE_LIMIT_BUSINESS_PER_DAY=5000
RATE_LIMIT_BUSINESS_PER_MONTH=100000

# ENTERPRISE tier (default: 1,000 req/min, 10,000 req/day, 1,000,000 req/month)
RATE_LIMIT_ENTERPRISE_PER_MINUTE=1000
RATE_LIMIT_ENTERPRISE_PER_DAY=10000
RATE_LIMIT_ENTERPRISE_PER_MONTH=1000000
